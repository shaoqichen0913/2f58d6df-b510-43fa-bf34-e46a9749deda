{
  "name": "@shaoqichen0913/skill-framework-cli",
  "version": "1.0.4",
  "description": "CLI for the skill framework — install, discover, activate, and run agent skills",
  "license": "MIT",
  "type": "module",
  "bin": {
    "skills": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "pnpm --filter @shaoqichen0913/skill-framework build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@shaoqichen0913/skill-framework": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
