{
  "name": "skill-framework",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript framework for installing and using agent skills locally (OpenAI Codex compatible)",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/**/src/**/*.ts",
    "typecheck": "pnpm -r typecheck",
    "skills": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
